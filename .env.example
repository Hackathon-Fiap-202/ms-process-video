# Arquivo de Configuração de Variáveis de Ambiente
# Copie este arquivo para .env na raiz do projeto e ajuste conforme necessário
# Uso: source .env

# AWS Configuration
export AWS_REGION=us-east-1
export AWS_ACCOUNT_ID=123456789012

# Spring Boot Configuration
export SPRING_PROFILES_ACTIVE=dev
export SPRING_APPLICATION_NAME=process-video

# LocalStack Configuration
export AWS_ACCESS_KEY_ID=test
export AWS_SECRET_ACCESS_KEY=test
export AWS_SESSION_TOKEN=test

# LocalStack Endpoints
export LOCALSTACK_HOST=localhost
export LOCALSTACK_PORT=4566
export LOCALSTACK_URL=http://localhost:4566

# Spring Cloud AWS Configuration
export SPRING_CLOUD_AWS_REGION_STATIC=us-east-1
export SPRING_CLOUD_AWS_S3_ENDPOINT=http://localhost:4566
export SPRING_CLOUD_AWS_SQS_ENDPOINT=http://localhost:4566
export SPRING_CLOUD_AWS_CREDENTIALS_ACCESS_KEY=test
export SPRING_CLOUD_AWS_CREDENTIALS_SECRET_KEY=test

# Application Server Configuration
export SERVER_PORT=8080

# Logging Configuration
export LOGGING_LEVEL_ROOT=INFO
export LOGGING_LEVEL_COM_HACKATHON=DEBUG
export LOGGING_LEVEL_IO_AWSPRING_CLOUD=INFO

# SQS Configuration
export SQS_VIDEO_PROCESS_COMMAND_URL=http://localhost:4566/000000000000/video-process-command
export SQS_VIDEO_UPDATED_EVENT_URL=http://localhost:4566/000000000000/video-updated-event

# Application Configuration
export APP_FRAME_EXTRACTION_THREAD_POOL_SIZE=4
export APP_FRAME_EXTRACTION_QUEUE_CAPACITY=200
export APP_BUCKETS_VIDEO_INPUT_STORAGE=video-input-storage
export APP_BUCKETS_VIDEO_PROCESSED_STORAGE=video-processed-storage

# Docker Configuration
export DOCKER_BUILDKIT=1
export DOCKER_COMPOSE_BUILDKIT=1

# Terraform Configuration (opcional, para testes de Terraform)
export TF_LOG=INFO
export TF_INPUT=false

# Datadog Configuration (opcional)
export DD_SERVICE=process-video
export DD_ENV=dev
export DD_VERSION=0.0.1

